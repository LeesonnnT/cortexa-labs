{
  "name": "cortexa-labs",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "cortexa-labs",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*",
        "workspace/*",
        "adapters/*",
        "skills/*",
        "workflows/*"
      ]
    },
    "adapters/base": {
      "name": "@ctx/adapter-base",
      "version": "0.1.0"
    },
    "apps/cli": {
      "name": "@cortexa-labs/cli",
      "version": "0.5.4",
      "license": "MIT",
      "bin": {
        "ctx": "src/index.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "apps/create-cortexa": {
      "version": "0.1.3",
      "license": "MIT",
      "bin": {
        "create-cortexa": "src/index.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@cortexa-labs/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@ctx/adapter-base": {
      "resolved": "adapters/base",
      "link": true
    },
    "node_modules/@ctx/graph": {
      "resolved": "workspace/graph",
      "link": true
    },
    "node_modules/@ctx/ownership": {
      "resolved": "workspace/ownership",
      "link": true
    },
    "node_modules/@ctx/resolver": {
      "resolved": "workspace/resolver",
      "link": true
    },
    "node_modules/@ctx/runtime": {
      "resolved": "workspace/runtime",
      "link": true
    },
    "node_modules/@ctx/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@ctx/skill-review": {
      "resolved": "skills/review",
      "link": true
    },
    "node_modules/@ctx/workflow-review": {
      "resolved": "workflows/review",
      "link": true
    },
    "node_modules/create-cortexa": {
      "resolved": "apps/create-cortexa",
      "link": true
    },
    "packages/shared": {
      "name": "@ctx/shared",
      "version": "0.1.0"
    },
    "skills/review": {
      "name": "@ctx/skill-review",
      "version": "0.1.0"
    },
    "workflows/review": {
      "name": "@ctx/workflow-review",
      "version": "0.1.0"
    },
    "workspace/graph": {
      "name": "@ctx/graph",
      "version": "0.1.0"
    },
    "workspace/ownership": {
      "name": "@ctx/ownership",
      "version": "0.1.0"
    },
    "workspace/resolver": {
      "name": "@ctx/resolver",
      "version": "0.1.0"
    },
    "workspace/runtime": {
      "name": "@ctx/runtime",
      "version": "0.1.0"
    }
  }
}
